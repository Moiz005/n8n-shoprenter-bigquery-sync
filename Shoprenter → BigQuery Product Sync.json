    {
      "parameters": {
        "jsCode": "const products = items[0].json.items;\n\nconst syncRunId = `SYNC_${Date.now()}`;\nconst syncTime = new Date().toISOString();\n\nreturn products.map(p => {\n\n  const stock1 = parseFloat(p.stock1 || 0);\n  const stock2 = parseFloat(p.stock2 || 0);\n  const stock3 = parseFloat(p.stock3 || 0);\n  const stock4 = parseFloat(p.stock4 || 0);\n\n  return {\n    json: {\n\n      sr_product_id: String(p.id || \"\"),\n\n      inner_id: String(p.innerId || \"\"),\n\n      sku: String(p.sku || \"\"),\n\n      product_name_hu: String(p.sku || \"\"),\n\n      short_description_hu: \"\",\n\n      long_description_hu: \"\",\n\n      net_price: parseFloat(p.price || 0),\n\n      gross_price: parseFloat(p.price || 0),\n\n      currency_code: \"HUF\",\n\n      stock_1: stock1,\n\n      stock_2: stock2,\n\n      stock_3: stock3,\n\n      stock_4: stock4,\n\n      total_stock:\n        stock1 +\n        stock2 +\n        stock3 +\n        stock4,\n\n      manufacturer: String(\n        p.manufacturer?.href || \"\"\n      ),\n\n      primary_product_image: String(\n        p.allImages?.mainImage || \"\"\n      ),\n\n      weight: parseFloat(p.weight || 0),\n\n      width: parseFloat(p.width || 0),\n\n      height: parseFloat(p.height || 0),\n\n      length: parseFloat(p.length || 0),\n\n      status: String(p.status || \"\"),\n\n      orderable_product: String(\n        p.orderable || \"\"\n      ),\n\n      reduce_stock: String(\n        p.subtractStock || \"\"\n      ),\n\n      measurement_unit_hu: \"\",\n\n      date_created: p.dateCreated || null,\n\n      date_updated: p.dateUpdated || null,\n\n      inserted_at: syncTime,\n\n      last_synced_at: syncTime,\n\n      is_active: true,\n\n      sync_run_id: syncRunId,\n\n      sync_status: \"success\"\n    }\n  };\n});"
      },
