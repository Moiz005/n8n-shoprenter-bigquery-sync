        "sqlQuery": "MERGE `bearings-hu-website.shoprenter.products_v2` T\n\nUSING (\n\n  SELECT *\n  FROM (\n\n    SELECT *,\n           ROW_NUMBER() OVER (\n             PARTITION BY sr_product_id\n             ORDER BY inserted_at DESC\n           ) AS rn\n\n    FROM `bearings-hu-website.shoprenter.products_staging`\n\n  )\n\n  WHERE rn = 1\n\n) S\n\nON T.sr_product_id = S.sr_product_id\n\nWHEN MATCHED THEN\nUPDATE SET\n\n  T.inner_id = S.inner_id,\n  T.sku = S.sku,\n  T.product_name_hu = S.product_name_hu,\n  T.short_description_hu = S.short_description_hu,\n  T.long_description_hu = S.long_description_hu,\n\n  T.net_price = S.net_price,\n  T.gross_price = S.gross_price,\n  T.currency_code = S.currency_code,\n\n  T.stock_1 = S.stock_1,\n  T.stock_2 = S.stock_2,\n  T.stock_3 = S.stock_3,\n  T.stock_4 = S.stock_4,\n  T.total_stock = S.total_stock,\n\n  T.manufacturer = S.manufacturer,\n  T.primary_product_image = S.primary_product_image,\n\n  T.weight = S.weight,\n  T.width = S.width,\n  T.height = S.height,\n  T.length = S.length,\n\n  T.status = S.status,\n  T.orderable_product = S.orderable_product,\n  T.reduce_stock = S.reduce_stock,\n\n  T.measurement_unit_hu = S.measurement_unit_hu,\n\n  T.date_created = S.date_created,\n  T.date_updated = S.date_updated,\n\n  T.last_synced_at = CURRENT_TIMESTAMP(),\n\n  T.is_active = S.is_active,\n\n  T.sync_run_id = S.sync_run_id,\n  T.sync_status = S.sync_status\n\nWHEN NOT MATCHED THEN\n\nINSERT (\n  sr_product_id,\n  inner_id,\n  sku,\n  product_name_hu,\n  short_description_hu,\n  long_description_hu,\n\n  net_price,\n  gross_price,\n  currency_code,\n\n  stock_1,\n  stock_2,\n  stock_3,\n  stock_4,\n  total_stock,\n\n  manufacturer,\n  primary_product_image,\n\n  weight,\n  width,\n  height,\n  length,\n\n  status,\n  orderable_product,\n  reduce_stock,\n\n  measurement_unit_hu,\n\n  date_created,\n  date_updated,\n\n  inserted_at,\n  last_synced_at,\n\n  is_active,\n\n  sync_run_id,\n  sync_status\n\n)\n\nVALUES (\n\n  S.sr_product_id,\n  S.inner_id,\n  S.sku,\n  S.product_name_hu,\n  S.short_description_hu,\n  S.long_description_hu,\n\n  S.net_price,\n  S.gross_price,\n  S.currency_code,\n\n  S.stock_1,\n  S.stock_2,\n  S.stock_3,\n  S.stock_4,\n  S.total_stock,\n\n  S.manufacturer,\n  S.primary_product_image,\n\n  S.weight,\n  S.width,\n  S.height,\n  S.length,\n\n  S.status,\n  S.orderable_product,\n  S.reduce_stock,\n\n  S.measurement_unit_hu,\n\n  S.date_created,\n  S.date_updated,\n\n  S.inserted_at,\n  CURRENT_TIMESTAMP(),\n\n  S.is_active,\n\n  S.sync_run_id,\n  S.sync_status\n);",
